# Local dev port (Render sets its own PORT automatically in production — leave as is)
PORT=3333

# Comma-separated list of allowed frontend origins (no spaces needed, trimmed automatically)
# Local dev + your live Vercel URL, e.g.:
# CLIENT_URL=http://localhost:5173,https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# Change these before deploying anywhere public
JWT_SECRET=nexora_super_secret_change_this_2035
ADMIN_USERNAME=admin
ADMIN_PASSWORD=nexora2035
